# Database
DATABASE_URL=postgresql://tst_user:tst_pass@localhost:5432/tst_hotels

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=tst_super_secret_jwt_2026
JWT_REFRESH_SECRET=tst_refresh_secret_jwt_2026

# App
PORT=3001
NODE_ENV=development

# Third-party keys (place real keys in a private .env)
STRIPE_SECRET_KEY=sk_test_placeholder
MPESA_CONSUMER_KEY=placeholder
MPESA_CONSUMER_SECRET=placeholder
SENDGRID_API_KEY=SG.placeholder

# Frontend/admin URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
DATABASE_URL=postgresql://tst_user:tst_pass@localhost:5432/tst_hotels
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_this_to_a_secure_random_string
JWT_REFRESH_SECRET=change_this_refresh_secret_too
PORT=3001
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://api.tsthotels.com/v1/payments/mpesa/callback

# SendGrid
SENDGRID_API_KEY=SG.your_key
SENDGRID_FROM=noreply@tsthotels.com

# AWS S3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=tst-hotels-assets

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
